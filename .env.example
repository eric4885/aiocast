# ─── Cloudflare Workers deploy ─────────────────────────────────────────────
# Plain-text runtime vars live in wrangler.jsonc (committed) — they survive Git deploys.
# Secrets ONLY in Cloudflare dashboard (or `wrangler secret put`): OPENAI_API_KEY,
# RESEND_API_KEY, UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN.
# After changing wrangler.jsonc vars, push to main to redeploy.
# Public HTTPS URL (no trailing slash). Used in emails, sitemap, canonical URLs.
NEXT_PUBLIC_SITE_URL=https://aiocast.com

# Resend — https://resend.com — transactional email (subscribe + growth pack links)
RESEND_API_KEY=
# Must be a verified sender domain in Resend
RESEND_FROM_EMAIL=AioCast <hello@aiocast.com>
# CAN-SPAM postal address in email footers (single line or use \\n between lines)
LEGAL_MAILING_ADDRESS=

# Upstash Redis — https://upstash.com — required on Vercel/serverless for job storage & rate limits
# On a single VPS you can omit these; the app falls back to .data/aiocast-store.json
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Recommended ───────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (loads only after cookie “Accept analytics”)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional embedded contact form (Tally, Typeform, etc.)
NEXT_PUBLIC_CONTACT_FORM_EMBED_URL=

# Optional social profile URLs for footer icons
# NEXT_PUBLIC_SOCIAL_X=https://twitter.com/yourhandle
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/yourco
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/@yourchannel

# ─── Optional product tuning ───────────────────────────────────────────────
FREE_MONTHLY_LIMIT=3
# IP limits for generate-pack (ignored when RATE_LIMIT_DISABLED=true)
FREE_IP_DAILY_LIMIT=3
FREE_IP_COOLDOWN_SEC=60
# Set to true to disable email + IP limits while testing (remove or set false for production)
RATE_LIMIT_DISABLED=false

# OpenAI — server only (never NEXT_PUBLIC_*). Template fallback runs when disabled.
OPENAI_API_KEY=
# Optional relay/proxy base URL (required for third-party OpenAI-compatible keys in CN)
# Default: https://api.openai.com/v1 — copy the API base from your provider dashboard
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=false
OPENAI_LOG_USAGE=false
# Audio transcription for Generate pack (uses the same OPENAI_API_KEY)
OPENAI_TRANSCRIBE_MODEL=whisper-1
TRANSCRIBE_ENABLED=true

# Listen Notes API key (optional) for live title demand signals
LISTEN_NOTES_API_KEY=

# Title optimizer output language: en (default) / auto / zh
TITLE_OUTPUT_LANGUAGE=en
